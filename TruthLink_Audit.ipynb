    "# Create the \"Distortion Gap\" Bar Chart\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.barplot(x=results.index, y=results['Distortion (%)'], palette='Reds_r')\n",
    "\n",
    "# Add a title and labels\n",
    "plt.title('TruthLink Audit: Business KPI Distortion Analysis', fontsize=14, fontweight='bold')\n",
    "plt.ylabel('Percentage Distortion (Error) %')\n",
    "plt.axhline(0, color='black', lw=1) # Adds a baseline at zero\n",
    "\n",
    "# This adds the percentage labels on top of the bars\n",
    "for i, v in enumerate(results['Distortion (%)']):\n",
    "    plt.text(i, v + 0.5, f'{v:.1f}%', ha='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"

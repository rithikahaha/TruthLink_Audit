   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "class TruthLinkAudit:\n",
    "    def __init__(self, n_rows=1000):\n",
    "        self.n_rows = n_rows\n",
    "        self.df_truth = self._generate_clean_reality()\n",
    "        self.df_raw = self._inject_corruption()\n",
    "        \n",
    "    def _generate_clean_reality(self):\n",
    "        np.random.seed(42)\n",
    "        data = {\n",
    "            'order_id': range(1001, 1001 + self.n_rows),\n",
    "            'price': np.random.normal(1000, 150, self.n_rows).clip(300, 2000),\n",
    "            'is_returned': np.random.choice([0, 1], size=self.n_rows, p=[0.77, 0.23]),\n",
    "            'cost_multiplier': 0.75 \n",
    "        }\n",
    "        return pd.DataFrame(data)\n",
    "\n",
    "    def _inject_corruption(self):\n",
    "        df = self.df_truth.copy()\n",
    "        # Inject Duplicates\n",
    "        dupes = df.nlargest(80, 'price') \n",
    "        df = pd.concat([df, dupes], ignore_index=True)\n",
    "        # Inject Missing Values\n",
    "        null_indices = df[df['is_returned'] == 0].sample(frac=0.4, random_state=1).index\n",
    "        df.loc[null_indices, 'is_returned'] = np.nan\n",
    "        # Inject Outliers\n",
    "        outlier_idx = df.sample(15, random_state=42).index\n",
    "        df.loc[outlier_idx, 'price'] = df.loc[outlier_idx, 'price'] * 8\n",
    "        return df\n",
    "\n",
    "    def run_audit(self):\n",
    "        raw_kpis = self._calc(self.df_raw, \"Raw (Dirty)\")\n",
    "        truth_kpis = self._calc(self.df_truth, \"Truth (Clean)\")\n",
    "        comparison = pd.DataFrame([raw_kpis, truth_kpis]).set_index('Label').T\n",
    "        comparison['Distortion (%)'] = ((comparison['Raw (Dirty)'] - comparison['Truth (Clean)']) / comparison['Truth (Clean)']) * 100\n",
    "        return comparison\n",
    "\n",
    "    def _calc(self, df, label):\n",
    "        return {\n",
    "            'Label': label,\n",
    "            'Revenue': df['price'].sum(),\n",
    "            'AOV': df['price'].mean(),\n",
    "            'Return Rate (%)': df['is_returned'].mean() * 100\n",
    "        }\n",
    "\n",
    "# Execution\n",
    "audit = TruthLinkAudit()\n",
    "results = audit.run_audit()\n",
    "print(results.round(2))"
   ]
  },
